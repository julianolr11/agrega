{
  "appId": "com.agrega.app",
  "productName": "Agrega",
  "directories": {
    "output": "dist"
  },
  "files": [
    "dist/**/*",
    "electron/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "electron/assets",
      "to": "assets"
    }
  ],
  "asar": true,
  "extraMetadata": {
    "main": "electron/main.js"
  },
  "win": {
    "target": "nsis",
    "artifactName": "Agrega-Setup-${version}.${ext}",
    "icon": "electron/assets/agregaico.ico"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "perMachine": false,
    "runAfterFinish": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Agrega"
  }
}
