{
  "appId": "com.agrega.app",
  "productName": "Agrega",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "electron/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "electron/assets",
      "to": "assets"
    }
  ],
  "asar": true,
  "extraMetadata": {
    "main": "electron/main.js"
  },
  "win": {
    "target": "nsis",
    "artifactName": "Agrega-Setup-${version}.${ext}"
  }
}
